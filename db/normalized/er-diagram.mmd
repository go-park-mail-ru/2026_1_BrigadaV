erDiagram
    USER ||--o{ SESSION : has
    USER ||--o{ FAVORITE : adds
    PLACE ||--o{ FAVORITE : added
    PLACE ||--o{ PLACE_PHOTO : contains
    CATEGORY ||--o{ PLACE : belongs
    LOCALITY ||--o{ PLACE : located
    COUNTRY ||--o{ LOCALITY : contains

    USER {
        bigint id PK
        text email UK
        text nickname UK
        text password_hash
        timestamptz created_at
        timestamptz updated_at
    }

    SESSION {
        bigint id PK
        bigint user_id FK
        text session_token UK
        timestamptz expires_at
        timestamptz created_at
    }

    FAVORITE {
        bigint user_id FK
        bigint place_id FK
        timestamptz created_at
    }

    PLACE {
        bigint id PK
        text name
        text description
        bigint locality_id FK
        bigint category_id FK
        timestamptz created_at
        timestamptz updated_at
    }

    PLACE_PHOTO {
        bigint id PK
        bigint place_id FK
        text file_path
        boolean is_main
        timestamptz created_at
    }

    CATEGORY {
        bigint id PK
        text name UK
        text description
        timestamptz created_at
    }

    LOCALITY {
        bigint id PK
        text name
        bigint country_id FK
        numeric latitude
        numeric longitude
        timestamptz created_at
    }

    COUNTRY {
        bigint id PK
        text name UK
        timestamptz created_at
    }