{
  "id": null,
  "uid": "guidely-main",
  "title": "Guidely — All Services",
  "tags": ["guidely"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "🟢 Service Status (UP = 1, DOWN = 0)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "up{job=\"backend\"}",
          "legendFormat": "backend",
          "refId": "A"
        },
        {
          "expr": "up{job=\"auth\"}",
          "legendFormat": "auth",
          "refId": "B"
        },
        {
          "expr": "up{job=\"album\"}",
          "legendFormat": "album",
          "refId": "C"
        },
        {
          "expr": "up{job=\"review\"}",
          "legendFormat": "review",
          "refId": "D"
        }
      ],
      "datasource": "Prometheus"
    },

    {
      "id": 2,
      "title": "HTTP — Requests per Second (by service)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (job)",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },

    {
      "id": 3,
      "title": "HTTP — Error Rate (5xx) by service",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[1m])) by (job) / sum(rate(http_requests_total[1m])) by (job)",
          "legendFormat": "{{job}} error rate",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },

    {
      "id": 4,
      "title": "HTTP — Request Duration P50/P95/P99 (backend)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"backend\"}[1m])) by (le, path))",
          "legendFormat": "p50 {{path}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"backend\"}[1m])) by (le, path))",
          "legendFormat": "p95 {{path}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"backend\"}[1m])) by (le, path))",
          "legendFormat": "p99 {{path}}",
          "refId": "C"
        }
      ],
      "datasource": "Prometheus"
    },

    {
      "id": 5,
      "title": "HTTP — Requests by Method & Path (backend, top 10)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "topk(10, sum(rate(http_requests_total{job=\"backend\"}[1m])) by (method, path))",
          "legendFormat": "{{method}} {{path}}",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },

    {
      "id": 6,
      "title": "HTTP — Total Hits (last 5m)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 20, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total[5m]))",
          "legendFormat": "Total Hits",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },

    {
      "id": 7,
      "title": "HTTP — Total Errors (last 5m)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 20, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{status=~\"[45]..\"}[5m]))",
          "legendFormat": "Errors",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },

    {
      "id": 8,
      "title": "HTTP — Avg Response Time (last 5m)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 20, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 200 }, { "color": "red", "value": 1000 }] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "1000 * sum(rate(http_request_duration_seconds_sum[5m])) / sum(rate(http_request_duration_seconds_count[5m]))",
          "legendFormat": "Avg Latency",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },

    {
      "id": 9,
      "title": "HTTP — P95 Latency (last 5m)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 20, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 2000 }] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "expr": "1000 * histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },

    {
      "id": 10,
      "title": "gRPC — Requests per Second (by service)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(grpc_requests_total[1m])) by (job)",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },

    {
      "id": 11,
      "title": "gRPC — Error Rate by service",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(grpc_requests_total{status=\"ERROR\"}[1m])) by (job) / sum(rate(grpc_requests_total[1m])) by (job)",
          "legendFormat": "{{job}} error rate",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },

    {
      "id": 12,
      "title": "gRPC — Request Duration P95 by service",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(grpc_request_duration_seconds_bucket[1m])) by (le, job))",
          "legendFormat": "p95 {{job}}",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },

    {
      "id": 13,
      "title": "gRPC — Requests by Method",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum(rate(grpc_requests_total[1m])) by (service, method)",
          "legendFormat": "{{service}} / {{method}}",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },

    {
      "id": 20,
      "title": "System — CPU Usage %",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 40, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "CPU Usage",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },

    {
      "id": 21,
      "title": "System — Memory Usage %",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 40, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 95 }] }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))",
          "legendFormat": "Memory Usage",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },

    {
      "id": 22,
      "title": "System — Disk Usage %",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 40, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] }
        },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "100 * (1 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}))",
          "legendFormat": "Disk / Usage",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },

    {
      "id": 23,
      "title": "System — Memory (bytes)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 48, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes",
          "legendFormat": "Total",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemAvailable_bytes",
          "legendFormat": "Available",
          "refId": "B"
        },
        {
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "Used",
          "refId": "C"
        }
      ],
      "datasource": "Prometheus"
    },

    {
      "id": 24,
      "title": "System — Disk I/O",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 48, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total[1m])",
          "legendFormat": "Read {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_written_bytes_total[1m])",
          "legendFormat": "Write {{device}}",
          "refId": "B"
        }
      ],
      "datasource": "Prometheus"
    }
  ]
}
